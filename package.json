{
  "name": "freshstart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc -p config/tsconfig.json && vite build --config config/vite.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run --config config/vite.config.ts",
    "test:e2e": "node scripts/run-playwright.mjs test",
    "install:e2e-browsers": "node scripts/run-playwright.mjs install chromium",
    "tauri": "node scripts/run-tauri.mjs",
    "tauri:test": "node scripts/run-cargo.mjs test",
    "tauri:build": "node scripts/run-tauri.mjs build --no-bundle && node scripts/copy-release-exe.mjs",
    "tauri:bundle": "node scripts/run-tauri.mjs build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
